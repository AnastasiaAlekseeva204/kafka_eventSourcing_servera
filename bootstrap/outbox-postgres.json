{
  "name": "outbox-postgres",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "database.hostname": "academy_db", 
    "database.port": "5432",
    "database.user": "user",
    "database.password": "password",
    "database.dbname": "academy_db",
    "database.server.name": "dbserver1",
    "table.include.list": "public.outbox_student",
    "plugin.name": "pgoutput",
    "publication.autocreate.mode": "filtred",


    "transforms": "outbox",
    "transforms.outbox.types": "io.debezium.transforms.outbox.EventRouter",
    "transforms.outbox.router.by.field": "aggregate_type",
    "transforms.outbox.route.topic.replacement": "${routedByValues}",
    "trans.outbox.route.table.field.event.key": "aggregate_id"
  }
}